# Copy to .env and fill real values:
#   cp .env.example .env
#
# Local Postgres (after: docker compose up -d):
DATABASE_URL=postgresql://tradingbot:tradingbot@localhost:5432/tradingbot

# Required by config (use real keys for the bot; placeholders only for dashboard-only smoke test)
TELEGRAM_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
ANTHROPIC_API_KEY=sk-ant-api03-placeholder
NEWSAPI_KEY=placeholder
ALLOWED_TELEGRAM_IDS=123456789

# Optional
CAPITAL_MODE=demo
SIGNAL_PLATFORM_ENABLED=true
# Scanners: trade whenever setup forms (default true) — set false to restore UTC dead-zone / choppy skips
# BTC_SCAN_IGNORE_TIME_FILTERS=true
# GOLD_SCAN_IGNORE_TIME_FILTERS=true
# BTC_ORDERFLOW_GATE_ENABLED=false
# DASHBOARD_AUTH_TOKEN=secret   # if set, Monte Carlo POST needs: Authorization: Bearer secret
